# Environment Variables

# Database
DATABASE_URL=postgresql://exebox:exebox_dev@localhost:5432/exebox

# Redis
REDIS_URL=redis://localhost:6379

# API Server
API_PORT=4000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Worker
WORKER_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=1000
WORKER_HEALTH_PORT=4003
REAP_INTERVAL_MS=300000

# WebSocket Server
WS_PORT=4001
WS_HEALTH_PORT=4004

# Docker
DOCKER_SOCKET=/var/run/docker.sock
