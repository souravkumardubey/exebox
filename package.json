{
  "name": "exebox",
  "version": "0.1.0",
  "private": true,
  "description": "AI Code Sandbox — A REST API for AI agents to securely run untrusted code in isolated Docker containers",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "create-key": "tsx scripts/create-key.ts",
    "format": "prettier --write \"**/*.{ts,js,json,css,md}\""
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.24.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.0",
    "ts-node": "^10.9.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "prisma": "^6.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.12.1"
}
